---
import { Button, Collapse, Spoiler, Timeline } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'
import Substats from '@/components/about/Substats.astro'
import ToolSection from '@/components/about/ToolSection.astro'

const headings = [
  { depth: 2, slug: 'hobbies', text: '兴趣爱好' },
  { depth: 2, slug: 'tools', text: '常用工具' },
  { depth: 2, slug: 'social-networks', text: '社交网络' },
  { depth: 2, slug: 'gossips', text: '碎碎念' },
  { depth: 2, slug: 'about-blog', text: '关于本站' }
]
---

<PageLayout title='关于' {headings} comment>
  <p>开发者 / 设计师</p>
  <p>
    这里是个人简介，可以写一些关于自己的介绍。热爱技术，喜欢分享，希望能在这里记录自己的成长历程。
  </p>
  <p>
    座右铭：求知若饥，虚心若愚。<Spoiler>这里可以夹私货，比如为什么要演奏春日影！</Spoiler>
  </p>
  <Button title='赞助我' class='w-fit' href='/projects#sponsorship' variant='ahead' />

  {/* general-talk */}
  <h2 id='hobbies'>兴趣爱好</h2>
  <ul>
    <li>喜欢编程，热衷于探索新技术。</li>
    <li>爱好摄影，喜欢记录生活中的美好瞬间。</li>
    <li>喜欢阅读，尤其是技术类和科幻类书籍。</li>
    <li>偶尔打打游戏，放松一下。</li>
  </ul>

  {/* tools */}
  <h2 id='tools'>常用工具</h2>
  <p>目前使用的工具如下：</p>
  <ToolSection
    class='mb-5'
    title='设计'
    tools={[
      {
        name: 'Photoshop',
        description: '图片编辑',
        href: 'https://www.adobe.com/products/photoshop',
        icon: import('@/assets/tools/photoshop.svg?raw')
      },
      {
        name: 'Illustrator',
        description: '矢量绘图',
        href: 'https://www.adobe.com/products/illustrator',
        icon: import('@/assets/tools/illustrator.svg?raw')
      },
      {
        name: 'After Effects',
        description: '动效制作',
        href: 'https://www.adobe.com/products/aftereffects',
        icon: import('@/assets/tools/aftereffects.svg?raw')
      },
      {
        name: 'Premiere Pro',
        description: '视频剪辑',
        href: 'https://www.adobe.com/products/premiere',
        icon: import('@/assets/tools/premiere.svg?raw')
      }
    ]}
  />
  <ToolSection
    class='mb-5'
    title='效率工具'
    tools={[
      {
        name: 'Chrome',
        description: '浏览器',
        href: 'https://www.google.com/chrome/',
        icon: import('@/assets/tools/chrome.svg?raw')
      },
      {
        name: 'Firefox',
        description: '浏览器',
        href: 'https://www.mozilla.org/en-US/firefox',
        icon: import('@/assets/tools/firefox.svg?raw')
      },
      {
        name: 'Notion',
        description: '笔记工具',
        href: 'https://www.notion.so/',
        icon: import('@/assets/tools/notion.svg?raw')
      },
      {
        name: 'Typora',
        description: 'Markdown 编辑器',
        href: 'https://typora.io/',
        icon: import('@/assets/tools/typora.svg?raw')
      }
    ]}
  />
  <ToolSection
    class='mb-5'
    title='开发工具'
    tools={[
      {
        name: 'VS Code',
        description: '代码编辑器',
        href: 'https://code.visualstudio.com/',
        icon: import('@/assets/tools/vscode.svg?raw')
      },
      {
        name: 'Neovim',
        description: '代码编辑器',
        href: 'https://neovim.io/',
        icon: import('@/assets/tools/neovim.svg?raw')
      },
      {
        name: 'Sublime Text',
        description: '代码编辑器',
        href: 'https://www.sublimetext.com/',
        icon: import('@/assets/tools/sublime.svg?raw')
      }
    ]}
  />
  <ToolSection
    class='mb-5'
    title='操作系统'
    tools={[
      {
        name: 'Arch Linux',
        description: 'Linux 发行版',
        href: 'https://archlinux.org/',
        icon: import('@/assets/tools/archlinux.svg?raw')
      },
      {
        name: 'Ubuntu 24.04 LTS',
        description: 'Linux 发行版',
        href: 'https://ubuntu.com/',
        icon: import('@/assets/tools/ubuntu.svg?raw')
      },
      {
        name: 'MacOS Tahoe',
        description: 'MacBook Air',
        href: 'https://www.apple.com/macos/',
        icon: import('@/assets/tools/apple.svg?raw')
      },
      {
        name: 'Windows 11',
        description: 'Framework Laptop 16',
        href: 'https://news.microsoft.com/windows11-general-availability/',
        icon: import('@/assets/tools/windows11.svg?raw')
      }
    ]}
  />

  {/* social-networks */}
  <h2 id='social-networks'>社交网络</h2>
  <p>
    欢迎关注我的社交账号，一起交流学习。
  </p>
  <Substats
    stats={[
      {
        platform: 'GitHub',
        icon: 'github',
        link: 'https://github.com/cworld1',
        text: '粉丝',
        api: 'github/cworld1'
      },
      {
        platform: 'Telegram',
        icon: 'telegram',
        color: '#2ca5e0',
        link: 'https://t.me/cworld0_cn',
        text: '订阅者',
        api: 'telegram/cworld0_cn'
      },
      {
        platform: 'Steam',
        icon: 'steam',
        color: '#50769d',
        link: 'https://steamcommunity.com/id/cworld',
        text: '游戏',
        api: 'steamgames/76561199021278120'
      }
    ]}
  />

  {/* gossips */}
  <h2 id='gossips'>碎碎念</h2>
  <Collapse title='一些想说的话'>
    这里可以写一些随想、感悟或者日常碎碎念。生活不止眼前的代码，还有诗和远方。
  </Collapse>

  {/* about-blog */}
  <h2 id='about-blog'>关于本站</h2>
  <p>网站历史：</p>
  <Timeline
    events={[
      {
        date: '2024-04-29',
        content:
          '使用 <a href="https://astro.build/" target="_blank">Astro</a> 和 <a href="https://github.com/srleom/astro-theme-resume" target="_blank">Astro Theme Resume</a> 重构网站'
      },
      {
        date: '2024-07-26',
        content:
          '将网站抽象为主题并发布到 <a href="https://github.com/cworld1/astro-theme-pure"target="_blank">Github</a>'
      },
      {
        date: '2024-07-27',
        content: '开始编写网站文档'
      }
    ]}
  />
  <p>
    本站的顺利运行和个性化定制离不开以下优秀项目/服务商提供的资源和技术支持：
  </p>
  <ul>
    <li>域名：<a href='#' target='_blank'>Vercel</a></li>
    <li>
      框架与主题：<a href='https://astro.build/' target='_blank'>Astro</a> + <a
        href='https://github.com/cworld1/astro-theme-pure'
        target='_blank'>Astro Theme Pure</a
      >
    </li>
    <li>
      网站托管：<a href='https://vercel.com/' target='_blank'>Vercel</a>
    </li>
    <li>
      CI/CD：<a href='https://vercel.com/workflow' target='_blank'>Vercel Workflow</a>
    </li>
    <li>评论系统：<a href='https://waline.js.org' target='_blank'>Waline</a></li>
    <li>
      访问统计：<a href='https://supabase.com/' target='_blank'>Supabase</a> +
      <a href='https://waline.js.org/' target='_blank'>Waline</a>
    </li>
    <li>
      其他统计：<a href='https://github.com/spencerwooo/substats' target='_blank'
        >Substats</a
      >
    </li>
  </ul>
</PageLayout>
